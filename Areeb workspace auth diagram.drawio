        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    title[&lt;b&gt;INTERNAL APPS: COMBINED ARCHITECTURE (HEADLESS AUTH vs SILENT SSO)&lt;/b&gt;]\n    style title fill:#none,stroke:#none,font-size:16px,font-weight:bold\n    \n    title --&gt; Start_Opt1 &amp; Start_Opt2\n\n    %% --- PATH A: HEADLESS AUTH (Option 1) ---\n    subgraph Path_A [Option 1: Headless Auth (Via ARM Login Page)]\n        Start_Opt1([👤 User opens ARM login page]) --&gt; InputCredentials[Enters Email &amp; Password on ARM Custom UI]\n        InputCredentials --&gt; ForwardReq[ARM Backend forwards credentials via POST API to Workspace]\n    end\n\n    %% --- PATH B: SILENT SSO (Option 2) ---\n    subgraph Path_B [Option 2: Silent SSO (Via Workspace Dashboard)]\n        Start_Opt2([👤 User clicks ARM Icon from Workspace Launchpad]) --&gt; ReadCookie[Workspace Server reads the browser active Session Cookie]\n        ReadCookie --&gt; GenCode[Generate single-use short-lived Transient Auth Code in Cache/DB]\n        GenCode --&gt; Redirect[Redirect browser to ARM URL with ?code=xyz]\n        Redirect --&gt; CatchCode[ARM Backend intercepts Code and requests exchange via Back-Channel]\n    end\n\n    %% --- CENTRAL WORKSPACE CORE ---\n    subgraph Workspace_Hub [Workspace Central Processing]\n        ForwardReq --&gt; ValidateDirect{Are credentials valid?}\n        CatchCode --&gt; ValidateCode{Are Code &amp; Client Secret authentic?}\n        \n        ValidateDirect -- No --&gt; RetErr[Return HTTP 401: Invalid Credentials]\n        ValidateCode -- No --&gt; DenyExchange[Reject Token Exchange Request]\n        \n        ValidateDirect -- Yes --&gt; ResolveUser1[Resolve Global UUID &amp; local_db_id]\n        ValidateCode -- Yes --&gt; ResolveUser2[Resolve Global UUID &amp; local_db_id]\n    end\n\n    %% --- TOKEN MINTING &amp; CONVERGENCE ---\n    ResolveUser1 &amp; ResolveUser2 --&gt; MintJWT[Mint JWT Payload containing local_db_id]\n    MintJWT --&gt; SignHS256[Sign JWT using symmetric env&#39;INTERNAL_JWT_SECRET&#39; string]\n    \n    SignHS256 --&gt; DeliverToken[Deliver HS256 JWT to ARM Backend]\n\n    %% --- ARM LOCAL VERIFICATION ---\n    subgraph ARM_Local_Server [ARM Backend Processing]\n        DeliverToken --&gt; LocalVerify[ARM computes local HMAC Hash using its own env&#39;INTERNAL_JWT_SECRET&#39;]\n        LocalVerify --&gt; MatchCheck{Does incoming signature match computed local hash?}\n        MatchCheck -- No --&gt; AuthFail[Reject Request / Force Logout]\n        MatchCheck -- Yes --&gt; HydrateSession[Extract local_db_id &amp; Hydrate user context in-memory]\n    end\n\n    RetErr --&gt; DispErr[Display login error to the User on ARM Custom UI]\n    DenyExchange &amp; AuthFail --&gt; EndFail([❌ Authentication Failed])\n    HydrateSession --&gt; EndOk([🔓 ARM opens successfully using local_id = 145 data])&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="9TbrBP4bkvqMl7w75i3d-254">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
