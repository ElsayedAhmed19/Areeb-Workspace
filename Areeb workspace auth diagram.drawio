        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    title[&lt;b&gt;EXTERNAL APP SSO: COMBINED ARCHITECTURE (SP-INITIATED vs IdP-INITIATED)&lt;/b&gt;]\n    style title fill:#none,stroke:#none,font-size:16px,font-weight:bold\n    \n    title --&gt; Start_SP &amp; Start_IdP\n\n    %% --- PATH A: SP-INITIATED (Option 1) ---\n    subgraph Path_A [Option 1: Starting from Microsoft (SP-Initiated)]\n        Start_SP([👤 User opens teams.microsoft.com]) --&gt; InputEmail[Enters corporate email: ahmed@company.com]\n        InputEmail --&gt; Detect[Microsoft detects Domain Federation]\n        Detect --&gt; RedirIdP[Microsoft redirects browser to Workspace with SAML/OIDC Auth Request]\n    end\n\n    %% --- PATH B: IdP-INITIATED (Option 2) ---\n    subgraph Path_B [Option 2: Starting from Launchpad (IdP-Initiated)]\n        Start_IdP([👤 User clicks Teams Icon on Workspace Dashboard]) --&gt; ReadLaunchSsn[Workspace reads active session cookie directly]\n    end\n\n    %% --- CONVERGENCE &amp; PROCESSING HUB ---\n    subgraph Workspace_Core [Workspace IdP Core Processing]\n        RedirIdP --&gt; CheckSsn{Is active session cookie present?}\n        CheckSsn -- No --&gt; ShowLogin[Display Login UI &amp; Validate typed credentials]\n        CheckSsn -- Yes --&gt; AutoResolve[Bypass Login UI &amp; resolve profile صامتاً]\n        \n        ShowLogin &amp; AutoResolve &amp; ReadLaunchSsn --&gt; AuthCheck{Is user active &amp; allowed to access Teams?}\n        AuthCheck -- No --&gt; Block[Reject access &amp; display error]\n        \n        AuthCheck -- Yes --&gt; MintExtToken[Mint OIDC ID Token / SAML Assertion]\n        MintExtToken --&gt; SignKey[Cryptographically sign payload using Workspace RSA Private Key]\n    end\n\n    %% --- HANDOFF &amp; VALIDATION ---\n    SignKey --&gt; BuildForm[Return hidden HTML form to browser and execute Javascript Auto-Submit]\n    \n    subgraph Microsoft_Processing [Microsoft Cloud Verification]\n        BuildForm --&gt; CatchPayload[Microsoft receives signed token via POST at consumer callback endpoint]\n        CatchPayload --&gt; FetchPubKey[Fetch / Verify signature using Workspace RSA Public Key from JWKS]\n        FetchPubKey --&gt; AuthCheckMS{Is cryptographic signature 100% authentic?}\n        AuthCheckMS -- No --&gt; BlockAuth[Block access &amp; return federation error]\n        AuthCheckMS -- Yes --&gt; TrustProfile[Establish corporate session &amp; map identity claims]\n    end\n\n    BlockAuth &amp; Block --&gt; EndFail([❌ Access Blocked / Failed])\n    TrustProfile --&gt; EndOk([🔓 Microsoft Teams dashboard loads seamlessly with Zero Clicks])&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="9TbrBP4bkvqMl7w75i3d-201">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
