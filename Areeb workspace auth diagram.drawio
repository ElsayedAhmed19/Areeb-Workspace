        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n    actor Browser as Browser Client (Employee)\n    participant IdP as Identity Provider (IdP)\n    participant MS as Microsoft Teams Servers\n\n    Browser-&gt;&gt;IdP: 1. POST: Plaintext Credentials\n    Note over IdP: 2. Verify Bcrypt Hash\n    Note over IdP: 3. Join App Permissions Table\n    Note over IdP: 4. Generate IdP Session Cookie\n    Note over IdP: 5. Mint Crypto Token (RS256 SAML Assertion)\n    IdP-&gt;&gt;Browser: 6. Return Hidden Auto-Submit HTML Form Layout\n    \n    Note over Browser: 7. JS Auto-Submits Form (Front-Channel)\n    Browser-&gt;&gt;MS: 8. POST: Signed SAML Token to Reply URL (ACS)\n    \n    Note over MS: 9. Verify Signature via Public Key (JWKS)\n    Note over MS: 10. Establish Active Session &amp; Cookies\n    MS-&gt;&gt;Browser: 11. HTTP 302 Redirect to teams.microsoft.com\n    \n    Note over Browser: 12. Opens Teams Web App / Triggers Deep Linking (teams://)&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="2ziR1LophP-P_8__MLdj-12">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
